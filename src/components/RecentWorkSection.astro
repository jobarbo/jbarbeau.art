---
import RecentWork from "./RecentWork.astro";
import {t, type Locale} from "../i18n";

interface Props {
	projects: import("astro:content").CollectionEntry<"project">[];
	locale?: Locale;
}

const {projects, locale = "en"} = Astro.props;
---

<section class='recent-work-section' aria-label={t(locale, "recentWork.sectionAria")}>
	<div class='recent-work-section__container'>
		<h2 class='recent-work-section__title'>{t(locale, "recentWork.sectionTitle")}</h2>
		<ul class='recent-work-section__list'>
			{projects.map((work) => <RecentWork work={work} locale={locale} />)}
		</ul>
	</div>
</section>
<style lang='scss'>
	@use "../styles/components/RecentWorkSection.scss";
</style>
