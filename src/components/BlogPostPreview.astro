---
interface Props {
	title: string;
	link: string;
	pubDate: string;
	excerpt: string;
	slug: string;
	image?: string;
	locale?: string;
}

const {title, link, pubDate, excerpt, slug, image, locale = "en"} = Astro.props;

const basePath = locale === "fr" ? "/fr/blog" : "/blog";
const readPost = locale === "fr" ? "Lire l'article →" : "Read full post →";
const viewOnSubstack = locale === "fr" ? "Voir sur Substack ↗" : "View on Substack ↗";

// Format the date
const date = new Date(pubDate);
const formattedDate = date.toLocaleDateString(locale === "fr" ? "fr-CA" : "en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<article class="blog-card">
	<a href={`${basePath}/${slug}`} class="blog-card__link">
		{
			image && (
				<div class="blog-card__image-wrapper">
					<img src={image} alt={title} class="blog-card__image" loading="lazy" />
				</div>
			)
		}
		<div class="blog-card__body">
			<h2 class="blog-card__title">{title}</h2>
			<time class="blog-card__date" datetime={date.toISOString()}>{formattedDate}</time>
			<p class="blog-card__excerpt">{excerpt}</p>
		</div>
	</a>
	<div class="blog-card__actions">
		<a href={`${basePath}/${slug}`} class="blog-card__read-link">{readPost}</a>
		<a href={link} target="_blank" rel="noopener noreferrer" class="blog-card__substack-link">{viewOnSubstack}</a>
	</div>
</article>

<style lang="scss">
	@use "../styles/components/Blog.scss";
</style>
