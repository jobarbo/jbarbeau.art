---
import Icon from "./Icon.astro";
import {t, getRelativeLocaleUrl, type Locale} from "../i18n";

interface Props {
	locale?: Locale;
}

const {locale = "en"} = Astro.props;
const otherLocale = locale === "en" ? "fr" : "en";
const currentPath = Astro.url.pathname;
const pathWithoutLocale = locale === "fr" ? currentPath.replace(/^\/fr/, "") || "/" : currentPath;
const pathForUrl = pathWithoutLocale.replace(/^\//, "") || "";
const switchUrl = pathForUrl === "" ? (otherLocale === "fr" ? "/fr" : "/") : getRelativeLocaleUrl(otherLocale, pathForUrl);
---

<nav class='navigation'>
	<div class='navigation__container'>
		<a href={locale === "en" ? "/" : "/fr"} class='navigation__site-title'> JBarbeau.art</a>
		<a href={locale === "en" ? "/blog" : "/fr/blog"} class='navigation__blog-link'>{t(locale, "nav.blog")}</a>
		<a href={switchUrl} class='navigation__lang-switch' aria-label={t(locale, "nav.langSwitch")}>{otherLocale}</a>
	</div>
</nav>

<style lang='scss'>
	@use "../styles/components/Nav.scss";
</style>
