---
import {t, getLocaleFromPath, type Locale} from "../i18n";

interface Props {
	title: string;
	images: string[];
	locale?: Locale;
}

const {title, images, locale: localeProp} = Astro.props;
const locale: Locale = localeProp ?? getLocaleFromPath(Astro.url.pathname);
---

<section class='collection-preview-grid' aria-label={t(locale, "collectionPreview.sectionAria")}>
	<div class='collection-preview-grid__header'>
		<h1 class='collection-preview-grid__title'>{title}</h1>
		<p class='collection-preview-grid__text'>{t(locale, "collectionPreview.headerText")}</p>
		<a class='collection-preview-grid__link button' href='https://retro-futura.netlify.app/' target='_blank'>
			<span> {t(locale, "collectionPreview.ctaText")}</span>
		</a>
	</div>
	<div class='collection-preview-grid__list' data-collection-preview-images>
		{
			images.length > 0 ? (
				images.map((src, index) => (
					<button type='button' class='collection-preview-grid__item' data-index={index} data-src={src} aria-label={t(locale, "collectionPreview.imageLabel", {index: index + 1})}>
						<img src={src} alt='' class='collection-preview-grid__img' loading='lazy' width='800' height='800' />
					</button>
				))
			) : (
				<p class='collection-preview-grid__empty'>{t(locale, "collectionPreview.emptyState")}</p>
			)
		}
	</div>
</section>

<style lang='scss'>
	@use "../styles/components/CollectionPreviewGrid.scss";
</style>
