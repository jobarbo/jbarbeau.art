---
import {t, getLocaleFromPath, type Locale} from "../i18n";

interface Props {
	title: string;
	images: string[];
	locale?: Locale;
}

const {title, images, locale: localeProp} = Astro.props;
const locale: Locale = localeProp ?? getLocaleFromPath(Astro.url.pathname);
---

<section class='collection-preview-grid' aria-label={t(locale, "collectionPreview.sectionAria")}>
	<div class='collection-preview-grid__header'>
		<h1 class='collection-preview-grid__title'>{title}</h1>
		<p class='collection-preview-grid__text'>{t(locale, "collectionPreview.headerText")}</p>
		<a class='collection-preview-grid__link' href='https://retro-futura.netlify.app/' target='_blank'>
			{t(locale, "collectionPreview.ctaText")}
		</a>
	</div>
	<div class='collection-preview-grid__list' data-collection-preview-images>
		{
			images.length > 0 ? (
				images.map((src, index) => (
					<button type='button' class='collection-preview-grid__item' data-index={index} data-src={src} aria-label={t(locale, "collectionPreview.imageLabel", {index: index + 1})}>
						<img src={src} alt='' class='collection-preview-grid__img' loading='lazy' width='800' height='800' />
					</button>
				))
			) : (
				<p class='collection-preview-grid__empty'>{t(locale, "collectionPreview.emptyState")}</p>
			)
		}
	</div>
</section>

<style lang='scss'>
	@use "../styles/base/functions" as *;
	@use "../styles/base/variables" as *;
	@use "../styles/base/mediaqueries" as *;

	.collection-preview-grid {
		padding: 2rem 1rem;
		margin: 0 auto;

		&__header {
			text-align: center;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}

		&__title {
			font-size: 2rem;
			margin-bottom: 2rem;
			text-align: center;
		}

		&__text {
			font-size: 1rem;
			margin-bottom: 2rem;
			text-align: center;
		}

		&__link {
			font-size: 1rem;
			color: white;
			font-weight: 600;
			font-family: var(--font-brand);
			padding: 0.5em 1em;
			margin-bottom: 2rem;
			background-color: black;
			border-radius: 50px;
			text-align: center;
			margin: 0 auto;
		}

		&__list {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 3rem;
		}

		&__item {
			appearance: none;
			border: none;
			padding: 0;
			margin: 0;
			background: none;
			cursor: pointer;
			display: block;
			overflow: hidden;
			border-radius: 4px;
			flex: 1 1 25%;
			width: fit-content;
		}

		&__img {
			width: auto;
			height: 100%;
			object-fit: contain;
			display: block;
			border: 1px solid $gray-200;
		}

		&__item:focus-visible {
			outline: 2px solid $teal;
			outline-offset: 2px;
		}

		&__empty {
			grid-column: 1 / -1;
			text-align: center;
			color: $gray-500;
			padding: 2rem;
		}
	}
</style>
