---
interface Props {
	id: string;
	title?: string;
}

const { id, title = "YouTube video" } = Astro.props;
const src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&autoplay=0&showinfo=0&enablejsapi=0`;
---

<div class="blog-youtube">
	<iframe
		src={src}
		title={title}
		frameborder="0"
		loading="lazy"
		allow="autoplay; fullscreen"
		allowfullscreen
	></iframe>
</div>

<style lang="scss">
	.blog-youtube {
		position: relative;
		width: 100%;
		padding-bottom: 56.25%; // 16:9
		margin: 1.5rem 0;
		border-radius: 4px;
		overflow: hidden;

		iframe {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			border: 0;
		}
	}
</style>
