---
import type {CollectionEntry} from "astro:content";
import Icon from "../components/Icon.astro";
import Button from "../components/Button.astro";
import {Image} from "astro:assets";
import {marked} from "marked";
import {t, type Locale} from "../i18n";

interface Props {
	work: CollectionEntry<"project">;
	locale?: Locale;
}

const {work, locale = "en"} = Astro.props;

const isBtnDisabled = work.data.url === "" || work.data.url === "undefined" ? "button--disabled" : "";
const descriptionText = locale === "fr" && work.data.descriptionFr ? work.data.descriptionFr : work.data.description;
const subtitleText = locale === "fr" && work.data.subtitleFr ? work.data.subtitleFr : work.data.subtitle;
let descriptionHtml = await marked(descriptionText);
// Escape literal <canvas> / </canvas> so they display as text, not as an actual element
descriptionHtml = descriptionHtml.replace(/<canvas>/gi, "&lt;canvas&gt;").replace(/<\/canvas>/gi, "&lt;/canvas&gt;");
---

<li class='recent-work__item'>
	<hr />
	<div class='recent-work__layout'>
		<h3 class='recent-work__title'>{work.data.title}</h3>
		<p class='recent-work__info'>{subtitleText}</p>
		<div class='recent-work__link-wrapper'>
			<Button label={t(locale, "recentWork.viewProject")} icon='external' href={work.data.url} target='_blank' class={`recent-work__link ${isBtnDisabled}`} />
			{work.data.isRedeemable && <Button label={t(locale, "recentWork.redeemHere")} icon='external' href={work.data.redeemUrl} target='_blank' class='recent-work__link' />}
			<Button label={t(locale, "recentWork.emailInquiries")} target='_blank' icon='email' href='mailto:barbeau.jonathan@gmail.com' class='recent-work__link' />
		</div>

		<div data-slider={work.data.slider} class='recent-work__image-row blaze-slider'>
			<div class='blaze-container'>
				<div class='blaze-track-container'>
					<div class='blaze-track'>
						{work.data.images.map((url, index) => <img alt={`${work.data.title} — artwork ${index + 1}`} class='recent-work__image' data-work-image width={300} height={200} loading='lazy' data-src={url} />)}
					</div>
				</div>
				<div class='recent-work__description'>
					<div class='recent-work__description-wrapper'>
						<h4 class='recent-work__description-title'>{t(locale, "recentWork.description")}</h4>
						<div class='recent-work__description-text' set:html={descriptionHtml} />
					</div>
					<!-- navigation buttons -->
					<div class='blaze-btn'>
						<button class='blaze-prev button'>
							<span><Icon className='icon--slider icon--slider-prev' isButton={true} icon={"chevron_left"} /></span>
							<span>{t(locale, "recentWork.previous")}</span>
						</button>
						<button class='blaze-next button'>
							<span>{t(locale, "recentWork.next")}</span>
							<span><Icon className='icon--slider icon--slider-next' isButton={true} icon={"chevron_right"} /></span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</li>

<script>
	import BlazeSlider from "blaze-slider";
	import "blaze-slider/dist/blaze.css";

	const observerConfig = {
		rootMargin: "800px 0px",
		threshold: 0.05,
	};

	const observer = new IntersectionObserver((entries, self) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				let image = entry.target as HTMLImageElement;
				if (image.dataset.src) {
					image.src = image.dataset.src;
					image.removeAttribute("loading");
					self.unobserve(entry.target);
				}
			}
		});
	}, observerConfig);

	const el_array = document.querySelectorAll("[data-slider]") as NodeListOf<HTMLElement>;

	el_array.forEach((el) => {
		// convert the data attribute to a an array by splitting it at the comma and then removing the comma
		let sliderArray = el.dataset.slider.split(",").map((item) => Number(item.trim()));
		const images = el.querySelectorAll("[data-work-image]") as NodeListOf<HTMLImageElement>;
		// Preload the images likely to be visible when the slider first appears
		const preloadCount = Math.max((sliderArray[0] || 3) + 1, 3);

		images.forEach((image, index) => {
			if (index < preloadCount && image.dataset.src) {
				image.src = image.dataset.src;
				image.removeAttribute("loading");
			} else {
				observer.observe(image);
			}
		});

		new BlazeSlider(el, {
			all: {
				transitionDuration: 300,
				slidesToShow: sliderArray[0] || 3, // use the first value of sliderArray, or default to 3 if it's not available
				loop: false,
			},
			"(max-width: 900px)": {
				slidesToShow: sliderArray[1] || 2, // use the second value of sliderArray, or default to 2 if it's not available
			},
			"(max-width: 500px)": {
				slidesToShow: sliderArray[2] || 1, // use the third value of sliderArray, or default to 1 if it's not available
			},
		});
	});
</script>

<style lang='scss'>
	@use "../styles/base/typography.scss";
	@use "../styles/components/Button.scss";
	@use "../styles/components/RecentWork.scss";
</style>
