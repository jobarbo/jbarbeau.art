---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const posts = await getCollection("blog", ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, pubDate, substackUrl, image, excerpt } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const ogImage = image || "/assets/og/profile.webp";
---

<Layout title={`${title} | Blog | J Barbeau`} description={excerpt ?? ""} image={ogImage} type="article">
	<section class="blog-single" aria-label="Blog post">
		<article class="blog-single__article">
			<h1 class="blog-single__title">{title}</h1>
			<div class="blog-single__meta">
				<time class="blog-single__date" datetime={pubDate.toISOString()}>{formattedDate}</time>
				<a href={substackUrl} target="_blank" rel="noopener noreferrer" class="blog-single__substack-link">View on Substack ↗</a>
			</div>
			<div class="blog-single__content">
				<Content />
			</div>
		</article>

		<div class="blog-single__footer">
			<a href="/blog" class="blog-single__back-link">← Back to all posts</a>
		</div>
	</section>
</Layout>

<style lang="scss">
	@use "../../styles/components/BlogSingle.scss";
</style>
