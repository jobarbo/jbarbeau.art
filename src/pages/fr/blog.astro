---
import Layout from "../../layouts/Layout.astro";
import BlogPostPreview from "../../components/BlogPostPreview.astro";
import { getCollection } from "astro:content";
import { t } from "../../i18n";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const enPosts = allPosts.filter((p) => !p.id.startsWith("fr/"));
const frPosts = allPosts.filter((p) => p.id.startsWith("fr/"));
const frSlugs = new Set(frPosts.map((p) => p.id.slice(3)));

// FR posts first, then EN posts without a FR translation (fallback)
const posts = [
	...frPosts,
	...enPosts.filter((p) => !frSlugs.has(p.id)),
].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout locale="fr" title={t("fr", "blog.metaTitle")} description={t("fr", "blog.metaDescription")}>
	<section class="blog" aria-label="Articles de blog">
		<div class="blog__header">
			<h1 class="blog__title">{t("fr", "blog.title")}</h1>
		</div>
		{
			posts.length > 0 ? (
				<div class="blog__grid">
					{posts.map((post) => (
						<BlogPostPreview
							title={post.data.title}
							link={post.data.substackUrl}
							pubDate={post.data.pubDate.toISOString()}
							excerpt={post.data.excerpt ?? ""}
							slug={post.id.startsWith("fr/") ? post.id.slice(3) : post.id}
							image={post.data.image}
							locale="fr"
						/>
					))}
				</div>
			) : (
				<p class="blog__empty">{t("fr", "blog.loadError")}</p>
			)
		}
	</section>
</Layout>

<style lang="scss">
	@use "../../styles/components/Blog.scss";
</style>
